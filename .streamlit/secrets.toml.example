# Example secrets file. Copy to .streamlit/secrets.toml and fill in keys.
# On Streamlit Cloud, paste this entire block into the app's "Secrets" UI
# (Manage app → Settings → Secrets) — do NOT commit the real values.

# --- Data providers ---------------------------------------------------------
FINNHUB_KEY = ""             # free: https://finnhub.io/dashboard
FRED_KEY    = ""             # free: https://fredaccount.stlouisfed.org/apikeys

# --- AI panel (any subset; Gemini is free) ----------------------------------
ANTHROPIC_API_KEY  = ""      # paid: https://console.anthropic.com/settings/keys
OPENAI_API_KEY     = ""      # paid: https://platform.openai.com/api-keys
GEMINI_API_KEY     = ""      # FREE: https://aistudio.google.com/app/apikey
GROQ_API_KEY       = ""      # FREE: https://console.groq.com/keys
OPENROUTER_API_KEY = ""      # FREE models: https://openrouter.ai/keys
XAI_API_KEY        = ""      # paid: https://console.x.ai (Grok)

# --- Alert channels (any subset; ntfy is free + push-to-phone) --------------
DISCORD_WEBHOOK_URL = ""     # Channel → Integrations → Webhooks → New
NTFY_TOPIC          = ""     # any unique string; subscribe in ntfy.sh app
NTFY_SERVER         = "https://ntfy.sh"
SLACK_WEBHOOK_URL   = ""     # api.slack.com/apps → Incoming Webhooks
SMTP_HOST = ""               # e.g. smtp.gmail.com
SMTP_PORT = "587"
SMTP_USER = ""
SMTP_PASS = ""               # Gmail: an App Password, not your login
SMTP_TO   = ""
SMTP_FROM = ""

# --- Alpaca brokerage (paper trading is free) -------------------------------
ALPACA_API_KEY    = ""       # https://app.alpaca.markets (toggle to Paper)
ALPACA_SECRET_KEY = ""
ALPACA_LIVE       = "false"  # "true" only to enable real-money endpoint
